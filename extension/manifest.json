{
  "manifest_version": 3,
  "name": "ScanSafe",
  "version": "1.0.0",
  "description": "Verify website BIS/FSSAI registration and trust score instantly.",
  "permissions": ["activeTab", "tabs"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "ScanSafe – Check Trust Score"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
